{
  "info": {
    "_postman_id": "97c216e0-d519-489e-882d-95737279ccff",
    "name": "RLOps E2E - Cologne3",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-Internal-API-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apiKeyOps}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "A. Health & Runtime",
      "item": [
        {
          "name": "A.1 Health Runtime",
          "request": {
            "method": "GET",
            "url": "{{baseUrlRuntime}}/health"
          }
        },
        {
          "name": "A.2 Health Ops",
          "request": {
            "method": "GET",
            "url": "{{baseUrlOps}}/health"
          }
        },
        {
          "name": "A.3 Runtime Ready",
          "request": {
            "method": "GET",
            "url": "{{baseUrlRuntime}}/ready"
          }
        },
        {
          "name": "A.4 List Active Areas",
          "request": {
            "method": "GET",
            "url": "{{baseUrlRuntime}}/api/algorithm/ai/areas"
          }
        },
        {
          "name": "A.5 Auto-sync Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrlOps}}/ops/auto-sync/status"
          }
        }
      ]
    },
    {
      "name": "B. Register Area For Cologne3",
      "item": [
        {
          "name": "B.1 Upsert area 1 -> cologne3",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrlOps}}/internal/sync/areas/{{areaId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceEventId\": \"evt-area-1-cologne3-001\",\n  \"areaName\": \"Cologne3 Demo Area\",\n  \"isActive\": true,\n  \"controllerVisible\": true,\n  \"tenantId\": \"{{tenantId}}\",\n  \"networkId\": \"{{networkId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "B.2 Upsert legacy artifact for readiness",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrlOps}}/internal/sync/areas/{{areaId}}/artifacts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceEventId\": \"evt-artifact-1-cologne3-001\",\n  \"policyVersion\": \"v2026.05.15\",\n  \"configVersion\": \"v2026.05.15\",\n  \"activate\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "B.3 Verify area readiness",
          "request": {
            "method": "GET",
            "url": "{{baseUrlRuntime}}/api/algorithm/ai/areas/{{areaId}}/readiness"
          }
        }
      ]
    },
    {
      "name": "C. Bundle Lifecycle",
      "item": [
        {
          "name": "C.1 Scan MinIO now",
          "request": {
            "method": "POST",
            "url": "{{baseUrlOps}}/ops/auto-sync/scan-now"
          }
        },
        {
          "name": "C.2 Read active Cologne3 bundle",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Active bundle exists\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.bundle_id) pm.environment.set(\"bundleId\", json.bundle_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrlOps}}/ops/networks/{{networkId}}/active"
          }
        },
        {
          "name": "C.3 List bundles for Cologne3",
          "request": {
            "method": "GET",
            "url": "{{baseUrlOps}}/ops/bundles?tenantId={{tenantId}}&networkId={{networkId}}"
          }
        },
        {
          "name": "C.4 Bundle audit events",
          "request": {
            "method": "GET",
            "url": "{{baseUrlOps}}/ops/bundles/{{bundleId}}/events"
          }
        }
      ]
    },
    {
      "name": "D. Inference",
      "item": [
        {
          "name": "D.1 Inference - Cologne3 5 controlled crosses",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"5 intersections\", () => pm.expect(json.numIntersections).to.eql(5));",
                  "pm.test(\"Has outputs\", () => pm.expect(json.algorithmOutputs.length).to.eql(5));"
                ]
              }
            }
