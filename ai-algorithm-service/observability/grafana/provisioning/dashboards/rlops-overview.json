{
  "title": "RLOps — Lop 2 Overview",
  "uid": "rlops-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Inference rate (req/s)",
      "id": 1,
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ai_inference_total[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (%)",
      "id": 2,
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(ai_inference_total{status=\"error\"}[5m])) / clamp_min(sum(rate(ai_inference_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inference latency p50/p95/p99 (ms)",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(ai_inference_latency_ms_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ai_inference_latency_ms_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(ai_inference_latency_ms_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Guardrail violations / sec by rule",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (rule) (rate(ai_guardrail_violations_total[1m]))", "legendFormat": "{{rule}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Drift events / sec",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (network_id, severity) (rate(ai_drift_events_total[5m]))", "legendFormat": "{{network_id}}/{{severity}}", "refId": "A" }
      ]
    },
    {
      "type": "table",
      "title": "Active bundles",
      "id": 6,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "ai_bundle_active_info == 1", "refId": "A", "format": "table", "instant": true }
      ]
    }
  ]
}
